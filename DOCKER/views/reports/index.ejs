<div class="page-header">
  <div>
    <h2><i data-lucide="clipboard-list"></i> รายงาน</h2>
    <div class="breadcrumb">หน้าหลัก / รายงาน</div>
  </div>
</div>

<!-- Filters -->
<div class="card mb-2">
  <div class="card-body">
    <form method="GET" action="/reports">
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="report_type">ประเภทรายงาน</label>
          <select class="form-control" id="report_type" name="report_type">
            <option value="assets" <%=filters.report_type==='assets' ? 'selected' : '' %>>ทรัพย์สินทั้งหมด</option>
            <option value="withdrawals" <%=filters.report_type==='withdrawals' ? 'selected' : '' %>>รายการเบิก</option>
            <option value="borrows" <%=filters.report_type==='borrows' ? 'selected' : '' %>>รายการยืม-คืน</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="start_date">ตั้งแต่วันที่</label>
          <input type="date" class="form-control" id="start_date" name="start_date" value="<%= filters.start_date %>">
        </div>
        <div class="form-group">
          <label class="form-label" for="end_date">ถึงวันที่</label>
          <input type="date" class="form-control" id="end_date" name="end_date" value="<%= filters.end_date %>">
        </div>
      </div>
      <div class="btn-group mt-1">
        <button type="submit" class="btn btn-primary"><i data-lucide="search" style="width:14px;height:14px"></i> ค้นหา</button>
        <a href="/reports/export/csv?report_type=<%= filters.report_type %>&start_date=<%= filters.start_date %>&end_date=<%= filters.end_date %>"
          class="btn btn-success"><i data-lucide="download"></i> Export CSV</a>
      </div>
    </form>
  </div>
</div>

<!-- Results -->
<div class="card">
  <div class="card-header">
    <h3>
      <% if (filters.report_type==='assets' ) { %><i data-lucide="package"></i> รายงานทรัพย์สินทั้งหมด
        <% } else if (filters.report_type==='withdrawals' ) { %><i data-lucide="package-minus"></i> รายงานการเบิก
          <% } else { %><i data-lucide="repeat"></i> รายงานการยืม-คืน
            <% } %>
    </h3>
    <span class="badge badge-primary">
      <%= reportData.length %> รายการ
    </span>
  </div>
  <div class="card-body">
    <% if (reportData.length===0) { %>
      <div class="empty-state">
        <div class="empty-icon"><i data-lucide="bar-chart-3"></i></div>
        <h4>ไม่พบข้อมูล</h4>
        <p>ลองเปลี่ยนตัวกรองหรือช่วงเวลา</p>
      </div>
      <% } else if (filters.report_type==='assets' ) { %>
        <div class="table-responsive">
          <table>
            <thead>
              <tr>
                <th>รหัส</th>
                <th>ชื่อ</th>
                <th>หมวดหมู่</th>
                <th>ประเภท</th>
                <th>คงเหลือ</th>
                <th>หน่วย</th>
                <th>ราคา/หน่วย</th>
                <th>สถานที่</th>
                <th>วันที่เพิ่ม</th>
              </tr>
            </thead>
            <tbody>
              <% reportData.forEach(a=> { %>
                <tr>
                  <td>
                    <%= a.asset_code %>
                  </td>
                  <td><strong>
                      <%= a.name %>
                    </strong></td>
                  <td>
                    <%= a.category ? a.category.name : '-' %>
                  </td>
                  <td>
                    <span class="badge <%= a.type === 'consumable' ? 'badge-warning' : 'badge-info' %>">
                      <%= a.type==='consumable' ? 'ใช้แล้วหมดไป' : 'ยืม-คืน' %>
                    </span>
                  </td>
                  <td>
                    <%= a.quantity %>
                  </td>
                  <td>
                    <%= a.unit %>
                  </td>
                  <td>
                    <%= a.price_per_unit ? parseFloat(a.price_per_unit).toLocaleString('th-TH') + ' ฿' : '-' %>
                  </td>
                  <td>
                    <%= a.location || '-' %>
                  </td>
                  <td>
                    <%= a.createdAt ? new Date(a.createdAt).toLocaleString('th-TH',
                      {year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '-' %>
                  </td>
                </tr>
                <% }) %>
            </tbody>
          </table>
        </div>
        <% } else if (filters.report_type==='withdrawals' ) { %>
          <div class="table-responsive">
            <table>
              <thead>
                <tr>
                  <th>#</th>
                  <th>วันที่เบิก</th>
                  <th>ทรัพย์สิน</th>
                  <th>ผู้เบิก</th>
                  <th>จำนวน</th>
                  <th>วัตถุประสงค์</th>
                  <th>สถานะ</th>
                </tr>
              </thead>
              <tbody>
                <% reportData.forEach((w, i)=> { %>
                  <tr>
                    <td>
                      <%= i + 1 %>
                    </td>
                    <td>
                      <%= w.withdrawal_date ? new Date(w.withdrawal_date).toLocaleString('th-TH',
                        {year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '-' %>
                    </td>
                    <td><strong>
                        <%= w.asset ? w.asset.name : '-' %>
                      </strong></td>
                    <td>
                      <%= w.user ? w.user.full_name : '-' %>
                    </td>
                    <td>
                      <%= w.quantity %>
                    </td>
                    <td>
                      <%= w.purpose || '-' %>
                    </td>
                    <td>
                      <span
                        class="badge <%= w.status === 'approved' ? 'badge-success' : w.status === 'rejected' ? 'badge-danger' : 'badge-warning' %>">
                        <%= w.status==='approved' ? 'อนุมัติ' : w.status==='rejected' ? 'ปฏิเสธ' : 'รออนุมัติ' %>
                      </span>
                    </td>
                  </tr>
                  <% }) %>
              </tbody>
            </table>
          </div>
          <% } else { %>
            <div class="table-responsive">
              <table>
                <thead>
                  <tr>
                    <th>#</th>
                    <th>วันที่ยืม</th>
                    <th>ทรัพย์สิน</th>
                    <th>ผู้ยืม</th>
                    <th>จำนวน</th>
                    <th>วัตถุประสงค์</th>
                    <th>สถานะ</th>
                    <th>วันที่คืน</th>
                  </tr>
                </thead>
                <tbody>
                  <% reportData.forEach((b, i)=> { %>
                    <tr>
                      <td>
                        <%= i + 1 %>
                      </td>
                      <td>
                        <%= b.borrow_date ? new Date(b.borrow_date).toLocaleString('th-TH',
                          {year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '-' %>
                      </td>
                      <td><strong>
                          <%= b.asset ? b.asset.name : '-' %>
                        </strong></td>
                      <td>
                        <%= b.user ? b.user.full_name : '-' %>
                      </td>
                      <td>
                        <%= b.quantity %>
                      </td>
                      <td>
                        <%= b.purpose || '-' %>
                      </td>
                      <td>
                        <span
                          class="badge <%= b.status === 'returned' ? 'badge-success' : b.status === 'overdue' ? 'badge-danger' : 'badge-info' %>">
                          <%= b.status==='returned' ? 'คืนแล้ว' : b.status==='overdue' ? 'เกินกำหนด' : 'กำลังยืม' %>
                        </span>
                      </td>
                      <td>
                        <%= b.actual_return_date ? new Date(b.actual_return_date).toLocaleString('th-TH',
                          {year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '-' %>
                      </td>
                    </tr>
                    <% }) %>
                </tbody>
              </table>
            </div>
            <% } %>
  </div>
</div>