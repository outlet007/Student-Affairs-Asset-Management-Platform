<div class="page-header">
  <div>
    <h2><i data-lucide="tag"></i> รายละเอียดทรัพย์สิน</h2>
    <div class="breadcrumb">หน้าหลัก / ทรัพย์สิน / <%= asset.name %>
    </div>
  </div>
  <div class="btn-group">
    <a href="/assets" class="btn btn-outline"><i data-lucide="arrow-left" style="width:14px;height:14px"></i> กลับ</a>
    <% if (currentUser && currentUser.role==='admin' ) { %>
      <a href="/assets/edit/<%= asset.id %>" class="btn btn-warning"><i data-lucide="pencil" style="width:14px;height:14px"></i> แก้ไข</a>
      <% } %>
  </div>
</div>

<!-- Asset Info -->
<div class="charts-grid">
  <div class="card">
    <div class="card-header">
      <h3><i data-lucide="clipboard-list"></i> ข้อมูลทรัพย์สิน</h3>
      <span
        class="badge <%= asset.status === 'active' ? 'badge-success' : asset.status === 'damaged' ? 'badge-danger' : asset.status === 'repairing' ? 'badge-warning' : 'badge-info' %>">
        <%= asset.status==='active' ? 'ใช้งานได้' : asset.status==='damaged' ? 'ชำรุด' : asset.status==='repairing'
          ? 'ซ่อมแซม' : 'จำหน่ายแล้ว' %>
      </span>
    </div>
    <div class="card-body">
      <div class="detail-grid">
        <div class="detail-item">
          <span class="detail-label">รหัสทรัพย์สิน</span>
          <span class="detail-value"><strong>
              <%= asset.asset_code %>
            </strong></span>
        </div>
        <div class="detail-item">
          <span class="detail-label">ชื่อ</span>
          <span class="detail-value">
            <%= asset.name %>
          </span>
        </div>
        <div class="detail-item">
          <span class="detail-label">หมวดหมู่</span>
          <span class="detail-value">
            <%= asset.category ? asset.category.name : '-' %>
          </span>
        </div>
        <div class="detail-item">
          <span class="detail-label">ประเภท</span>
          <span class="detail-value">
            <span class="badge <%= asset.type === 'consumable' ? 'badge-warning' : 'badge-info' %>">
              <%= asset.type==='consumable' ? 'ใช้แล้วหมดไป' : 'ยืม-คืน' %>
            </span>
          </span>
        </div>
        <div class="detail-item">
          <span class="detail-label">จำนวนคงเหลือ</span>
          <span class="detail-value">
            <% if (asset.min_quantity> 0 && asset.quantity <= asset.min_quantity) { %>
                <span style="color: var(--danger); font-weight: 600;">
                  <%= asset.quantity %>
                    <%= asset.unit %> <i data-lucide="triangle-alert"></i>
                </span>
                <% } else { %>
                  <%= asset.quantity %>
                    <%= asset.unit %>
                      <% } %>
          </span>
        </div>
        <div class="detail-item">
          <span class="detail-label">จำนวนขั้นต่ำ</span>
          <span class="detail-value">
            <%= asset.min_quantity %>
              <%= asset.unit %>
          </span>
        </div>
        <div class="detail-item">
          <span class="detail-label">ราคาต่อหน่วย</span>
          <span class="detail-value">
            <%= asset.price_per_unit ? parseFloat(asset.price_per_unit).toLocaleString('th-TH') + ' ฿' : '-' %>
          </span>
        </div>
        <div class="detail-item">
          <span class="detail-label">สถานที่จัดเก็บ</span>
          <span class="detail-value">
            <%= asset.location || '-' %>
          </span>
        </div>
        <div class="detail-item">
          <span class="detail-label">วันที่เพิ่มเข้าระบบ</span>
          <span class="detail-value">
            <%= asset.createdAt ? new Date(asset.createdAt).toLocaleString('th-TH',
              {year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '-' %>
          </span>
        </div>
        <div class="detail-item">
          <span class="detail-label">แก้ไขล่าสุด</span>
          <span class="detail-value">
            <%= asset.updatedAt ? new Date(asset.updatedAt).toLocaleString('th-TH',
              {year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '-' %>
          </span>
        </div>
      </div>
      <% if (asset.description) { %>
        <div class="mt-2">
          <span class="detail-label">รายละเอียด</span>
          <p style="color: var(--text-secondary); font-size: 14px; margin-top: 5px;">
            <%= asset.description %>
          </p>
        </div>
        <% } %>
    </div>
  </div>

  <!-- Stats -->
  <div class="card">
    <div class="card-header">
      <h3><i data-lucide="bar-chart-3"></i> สรุปสถิติ</h3>
    </div>
    <div class="card-body">
      <div class="mini-stats">
        <div class="mini-stat">
          <div class="mini-stat-icon" style="background: rgba(99,102,241,0.15); color: #818cf8;"><i data-lucide="package-minus"></i></div>
          <div>
            <div class="mini-stat-value">
              <%= withdrawalCount %>
            </div>
            <div class="mini-stat-label">เบิกใช้ทั้งหมด</div>
          </div>
        </div>
        <div class="mini-stat">
          <div class="mini-stat-icon" style="background: rgba(59,130,246,0.15); color: #60a5fa;"><i data-lucide="repeat"></i></div>
          <div>
            <div class="mini-stat-value">
              <%= borrowCount %>
            </div>
            <div class="mini-stat-label">ยืมทั้งหมด</div>
          </div>
        </div>
        <div class="mini-stat">
          <div class="mini-stat-icon" style="background: rgba(245,158,11,0.15); color: #fbbf24;"><i data-lucide="clipboard-list"></i></div>
          <div>
            <div class="mini-stat-value">
              <%= activeBorrows %>
            </div>
            <div class="mini-stat-label">กำลังยืมอยู่</div>
          </div>
        </div>
        <div class="mini-stat">
          <div class="mini-stat-icon" style="background: rgba(34,197,94,0.15); color: #4ade80;"><i data-lucide="coins"></i></div>
          <div>
            <div class="mini-stat-value">
              <%= asset.price_per_unit ? (parseFloat(asset.price_per_unit) * asset.quantity).toLocaleString('th-TH')
                : '-' %> ฿
            </div>
            <div class="mini-stat-label">มูลค่ารวม</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Recent Withdrawals -->
<% if (recentWithdrawals.length> 0) { %>
  <div class="card mt-2">
    <div class="card-header">
      <h3><i data-lucide="package-minus"></i> ประวัติการเบิกล่าสุด</h3>
    </div>
    <div class="card-body">
      <div class="table-responsive">
        <table>
          <thead>
            <tr>
              <th>วันที่</th>
              <th>ผู้เบิก</th>
              <th>จำนวน</th>
              <th>วัตถุประสงค์</th>
              <th>สถานะ</th>
            </tr>
          </thead>
          <tbody>
            <% recentWithdrawals.forEach(w=> { %>
              <tr>
                <td>
                  <%= w.withdrawal_date ? new Date(w.withdrawal_date).toLocaleString('th-TH',
                    {year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '-' %>
                </td>
                <td>
                  <%= w.user ? w.user.full_name : '-' %>
                </td>
                <td>
                  <%= w.quantity %>
                </td>
                <td>
                  <%= w.purpose || '-' %>
                </td>
                <td>
                  <span
                    class="badge <%= w.status === 'approved' ? 'badge-success' : w.status === 'rejected' ? 'badge-danger' : 'badge-warning' %>">
                    <%= w.status==='approved' ? 'อนุมัติ' : w.status==='rejected' ? 'ปฏิเสธ' : 'รออนุมัติ' %>
                  </span>
                </td>
              </tr>
              <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <% } %>

    <!-- Recent Borrows -->
    <% if (recentBorrows.length> 0) { %>
      <div class="card mt-2">
        <div class="card-header">
          <h3><i data-lucide="repeat"></i> ประวัติการยืมล่าสุด</h3>
        </div>
        <div class="card-body">
          <div class="table-responsive">
            <table>
              <thead>
                <tr>
                  <th>วันที่ยืม</th>
                  <th>ผู้ยืม</th>
                  <th>จำนวน</th>
                  <th>วัตถุประสงค์</th>
                  <th>กำหนดคืน</th>
                  <th>สถานะ</th>
                </tr>
              </thead>
              <tbody>
                <% recentBorrows.forEach(b=> { %>
                  <tr>
                    <td>
                      <%= b.borrow_date ? new Date(b.borrow_date).toLocaleString('th-TH',
                        {year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '-' %>
                    </td>
                    <td>
                      <%= b.user ? b.user.full_name : '-' %>
                    </td>
                    <td>
                      <%= b.quantity %>
                    </td>
                    <td>
                      <%= b.purpose || '-' %>
                    </td>
                    <td>
                      <%= b.expected_return_date ? new Date(b.expected_return_date).toLocaleString('th-TH',
                        {year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '-' %>
                    </td>
                    <td>
                      <span
                        class="badge <%= b.status === 'returned' ? 'badge-success' : b.status === 'overdue' ? 'badge-danger' : 'badge-info' %>">
                        <%= b.status==='returned' ? 'คืนแล้ว' : b.status==='overdue' ? 'เกินกำหนด' : 'กำลังยืม' %>
                      </span>
                    </td>
                  </tr>
                  <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <% } %>