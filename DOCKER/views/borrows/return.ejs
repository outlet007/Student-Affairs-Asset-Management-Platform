<div class="page-header">
  <div>
    <h2><i data-lucide="download"></i> คืนทรัพย์สิน</h2>
    <div class="breadcrumb">หน้าหลัก / ยืม-คืน / คืน</div>
  </div>
  <a href="/borrows" class="btn btn-outline"><i data-lucide="arrow-left" style="width:14px;height:14px"></i> กลับ</a>
</div>

<div class="card">
  <div class="card-header">
    <h3>รายละเอียดการยืม</h3>
  </div>
  <div class="card-body">
    <div class="form-row mb-3">
      <div class="form-group">
        <label class="form-label">ทรัพย์สิน</label>
        <input type="text" class="form-control" value="<%= borrow.asset ? borrow.asset.name : '-' %>" disabled>
      </div>
      <div class="form-group">
        <label class="form-label">ผู้ยืม</label>
        <input type="text" class="form-control" value="<%= borrow.user ? borrow.user.full_name : '-' %>" disabled>
      </div>
    </div>
    <div class="form-row mb-3">
      <div class="form-group">
        <label class="form-label">จำนวน</label>
        <input type="text" class="form-control" value="<%= borrow.quantity %>" disabled>
      </div>
      <div class="form-group">
        <label class="form-label">วันที่ยืม</label>
        <input type="text" class="form-control" value="<%= borrow.borrow_date ? new Date(borrow.borrow_date).toLocaleString('th-TH', {year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '-' %>" disabled>
      </div>
    </div>

    <form action="/borrows/return/<%= borrow.id %>" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label class="form-label" for="return_condition">สภาพทรัพย์สินตอนคืน</label>
        <textarea class="form-control" id="return_condition" name="return_condition" placeholder="ระบุสภาพทรัพย์สิน เช่น ปกติ, ชำรุด, ต้องซ่อม"></textarea>
      </div>
      <button type="submit" class="btn btn-success"><i data-lucide="download"></i> ยืนยันการคืน</button>
    </form>
  </div>
</div>
