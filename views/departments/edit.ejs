<div class="page-header">
  <div>
    <h2><i data-lucide="pencil" style="width:14px;height:14px"></i> แก้ไขหน่วยงาน</h2>
    <div class="breadcrumb">หน้าหลัก / หน่วยงาน / แก้ไข</div>
  </div>
  <a href="/departments" class="btn btn-outline"><i data-lucide="arrow-left" style="width:14px;height:14px"></i> กลับ</a>
</div>

<div class="card">
  <div class="card-body">
    <form action="/departments/edit/<%= department.id %>" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label class="form-label" for="code">รหัสหน่วยงาน (ตัวย่อ) *</label>
        <input type="text" class="form-control" id="code" name="code" value="<%= department.code || '' %>" required placeholder="เช่น REG, HR, IT" maxlength="20">
      </div>
      <div class="form-group">
        <label class="form-label" for="name">ชื่อหน่วยงาน *</label>
        <input type="text" class="form-control" id="name" name="name" value="<%= department.name %>" required>
      </div>
      <div class="form-group">
        <label class="form-label" for="description">รายละเอียด</label>
        <textarea class="form-control" id="description" name="description" rows="3"><%= department.description || '' %></textarea>
      </div>
      <button type="submit" class="btn btn-primary">💾 บันทึก</button>
    </form>
  </div>
</div>
