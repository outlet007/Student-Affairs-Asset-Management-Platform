<div class="page-header">
  <div>
    <h2><i data-lucide="repeat"></i> การยืม-คืนทรัพย์สิน</h2>
    <div class="breadcrumb">หน้าหลัก / ยืม-คืน</div>
  </div>
  <a href="/borrows/create" class="btn btn-primary"><i data-lucide="plus" style="width:14px;height:14px"></i> ยืมทรัพย์สิน</a>
</div>

<div class="filter-bar">
  <div class="filter-tabs">
    <a href="/borrows" class="filter-tab <%= !filterStatus ? 'active' : '' %>">ทั้งหมด</a>
    <a href="/borrows?status=pending" class="filter-tab <%= filterStatus === 'pending' ? 'active' : '' %>">รออนุมัติ</a>
    <a href="/borrows?status=borrowing" class="filter-tab <%= filterStatus === 'borrowing' ? 'active' : '' %>">กำลังยืม</a>
    <a href="/borrows?status=returned" class="filter-tab <%= filterStatus === 'returned' ? 'active' : '' %>">คืนแล้ว</a>
    <a href="/borrows?status=overdue" class="filter-tab <%= filterStatus === 'overdue' ? 'active' : '' %>">เกินกำหนด</a>
    <a href="/borrows?status=rejected" class="filter-tab <%= filterStatus === 'rejected' ? 'active' : '' %>">ปฏิเสธ</a>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <% if (borrows.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon"><i data-lucide="repeat"></i></div>
        <h4>ไม่มีรายการยืม</h4>
        <p>ยังไม่มีรายการยืมทรัพย์สิน</p>
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>ทรัพย์สิน</th>
              <th>ผู้ยืม</th>
              <th>จำนวน</th>
              <th>วัตถุประสงค์</th>
              <th>วันที่ยืม</th>
              <th>กำหนดคืน</th>
              <th>สถานะ</th>
              <th>จัดการ</th>
            </tr>
          </thead>
          <tbody>
            <% borrows.forEach((b, i) => { %>
              <tr>
                <td><%= (pagination.currentPage - 1) * pagination.limit + i + 1 %></td>
                <td><strong><%= b.asset ? b.asset.name : '-' %></strong></td>
                <td><%= b.user ? b.user.full_name : '-' %></td>
                <td><%= b.quantity %></td>
                <td><%= b.purpose || '-' %></td>
                <td><%= b.borrow_date ? new Date(b.borrow_date).toLocaleString('th-TH', {year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '-' %></td>
                <td><%= b.expected_return_date ? new Date(b.expected_return_date).toLocaleString('th-TH', {year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '-' %></td>
                <td>
                  <span class="badge <%= b.status === 'returned' ? 'badge-success' : b.status === 'overdue' ? 'badge-danger' : b.status === 'pending' ? 'badge-warning' : b.status === 'rejected' ? 'badge-danger' : 'badge-info' %>">
                    <%= b.status === 'returned' ? 'คืนแล้ว' : b.status === 'overdue' ? 'เกินกำหนด' : b.status === 'pending' ? 'รออนุมัติ' : b.status === 'rejected' ? 'ปฏิเสธ' : 'กำลังยืม' %>
                  </span>
                  <% if (b.status === 'rejected' && b.rejection_reason) { %>
                    <div style="font-size:11px; color:var(--text-muted); margin-top:3px;">เหตุผล: <%= b.rejection_reason %></div>
                  <% } %>
                </td>
                <td>
                  <% if (b.status === 'pending' && currentUser && currentUser.role === 'admin') { %>
                    <div class="btn-group">
                      <form action="/borrows/approve/<%= b.id %>" method="POST" style="display:inline">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="btn btn-success btn-xs"><i data-lucide="check-circle" style="width:16px;height:16px"></i> อนุมัติ</button>
                      </form>
                      <button type="button" class="btn btn-danger btn-xs btn-reject-borrow" data-id="<%= b.id %>"><i data-lucide="x-circle" style="width:16px;height:16px"></i> ปฏิเสธ</button>
                    </div>
                  <% } else if (b.status === 'borrowing' || b.status === 'overdue') { %>
                    <a href="/borrows/return/<%= b.id %>" class="btn <%= b.status === 'overdue' ? 'btn-warning' : 'btn-success' %> btn-xs"><i data-lucide="download"></i> คืน</a>
                  <% } else if (b.status === 'returned') { %>
                    <span style="color: var(--text-muted);">คืนเมื่อ <%= b.actual_return_date ? new Date(b.actual_return_date).toLocaleString('th-TH', {year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '-' %></span>
                  <% } else { %>
                    <span style="color: var(--text-muted);">-</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <%- include('../partials/pagination', { pagination, buildQuery }) %>
    <% } %>
  </div>
</div>

<!-- Reject Borrow Modal -->
<div class="modal-overlay" id="rejectBorrowModal">
  <div class="modal-content">
    <h3><i data-lucide="x-circle" style="width:16px;height:16px"></i> ปฏิเสธการยืม</h3>
    <form id="rejectBorrowForm" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label class="form-label" for="borrow_rejection_reason">เหตุผลที่ปฏิเสธ</label>
        <textarea class="form-control" id="borrow_rejection_reason" name="rejection_reason" placeholder="ระบุเหตุผล (ไม่บังคับ)"></textarea>
      </div>
      <div class="modal-actions">
        <button type="button" class="btn btn-outline" onclick="document.getElementById('rejectBorrowModal').classList.remove('active')">ยกเลิก</button>
        <button type="submit" class="btn btn-danger">ยืนยันปฏิเสธ</button>
      </div>
    </form>
  </div>
</div>

<script>
document.querySelectorAll('.btn-reject-borrow').forEach(btn => {
  btn.addEventListener('click', () => {
    const id = btn.dataset.id;
    document.getElementById('rejectBorrowForm').action = '/borrows/reject/' + id;
    document.getElementById('rejectBorrowModal').classList.add('active');
  });
});
</script>
