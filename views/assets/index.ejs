<div class="page-header">
  <div>
    <h2><i data-lucide="tag"></i> ทรัพย์สิน</h2>
    <div class="breadcrumb">หน้าหลัก / ทรัพย์สิน</div>
  </div>
  <% if (currentUser && (currentUser.role==='admin' || currentUser.role==='superadmin')) { %>
    <a href="/assets/create" class="btn btn-primary"><i data-lucide="plus" style="width:14px;height:14px"></i> เพิ่มทรัพย์สิน</a>
    <% } %>
</div>

<!-- Filters -->
<form method="GET" action="/assets">
  <div class="filter-bar">
    <div class="filter-tabs">
      <a href="/assets" class="filter-tab <%= !filters.type && filters.low_stock !== '1' ? 'active' : '' %>">ทั้งหมด</a>
      <a href="/assets?type=consumable"
        class="filter-tab <%= filters.type === 'consumable' ? 'active' : '' %>">ใช้แล้วหมดไป</a>
      <a href="/assets?type=borrowable"
        class="filter-tab <%= filters.type === 'borrowable' ? 'active' : '' %>">ยืม-คืนได้</a>
      <a href="/assets?low_stock=1"
        class="filter-tab <%= filters.low_stock === '1' ? 'active' : '' %>"><i data-lucide="triangle-alert" style="width:14px;height:14px"></i> ใกล้หมด</a>
    </div>
    <div class="search-input" style="position: relative; display: flex; align-items: center;">
      <i data-lucide="text-search" style="position: absolute; left: 10px; width: 14px; height: 14px; color: var(--text-color); opacity: 0.5;"></i>
      <input type="text" name="search" value="<%= filters.search %>" placeholder="ค้นหาชื่อหรือรหัส..." style="padding-left: 32px;">
    </div>
    <select class="form-control" name="category_id" style="max-width:200px" onchange="this.form.submit()">
      <option value="">-- หมวดหมู่ทั้งหมด --</option>
      <% categories.forEach(cat=> { %>
        <option value="<%= cat.id %>" <%=filters.category_id==cat.id ? 'selected' : '' %>><%= cat.name %>
        </option>
        <% }) %>
    </select>
    <% if (typeof departments !== 'undefined' && departments.length > 0) { %>
    <select class="form-control" name="department_id" style="max-width:200px" onchange="this.form.submit()">
      <option value="">-- หน่วยงานทั้งหมด --</option>
      <% departments.forEach(dept=> { %>
        <option value="<%= dept.id %>" <%=filters.department_id==dept.id ? 'selected' : '' %>><%= dept.name %>
        </option>
        <% }) %>
    </select>
    <% } %>
    <button type="submit" class="btn btn-outline btn-sm"><i data-lucide="search" style="width:14px;height:14px"></i> ค้นหา</button>
  </div>
</form>

<div class="card">
  <div class="card-body">
    <% if (assets.length===0) { %>
      <div class="empty-state">
        <div class="empty-icon"><i data-lucide="package"></i></div>
        <h4>ไม่พบทรัพย์สิน</h4>
        <p>ลองเปลี่ยนตัวกรอง หรือเพิ่มทรัพย์สินใหม่</p>
      </div>
      <% } else { %>
        <div class="table-responsive">
          <%
            const getSortIcon = (field) => {
              if (filters.sort === field) {
                return filters.order === 'ASC' ? ' <i data-lucide="arrow-up" style="width:14px;height:14px;display:inline"></i>' : ' <i data-lucide="arrow-down" style="width:14px;height:14px;display:inline"></i>';
              }
              return ' <i data-lucide="chevrons-up-down" style="width:14px;height:14px;display:inline;opacity:0.3"></i>';
            };
            
            const getSortUrl = (field) => {
              const newOrder = (filters.sort === field && filters.order === 'ASC') ? 'DESC' : 'ASC';
              let urlParams = new URLSearchParams();
              if (filters.type) urlParams.set('type', filters.type);
              if (filters.search) urlParams.set('search', filters.search);
              if (filters.category_id) urlParams.set('category_id', filters.category_id);
              if (filters.department_id) urlParams.set('department_id', filters.department_id);
              urlParams.set('sort', field);
              urlParams.set('order', newOrder);
              return '?' + urlParams.toString();
            };
          %>
          <table>
            <thead>
              <tr>
                <th><a href="<%= getSortUrl('asset_code') %>" style="color:inherit;text-decoration:none;display:flex;align-items:center;">รหัส<%- getSortIcon('asset_code') %></a></th>
                <th><a href="<%= getSortUrl('name') %>" style="color:inherit;text-decoration:none;display:flex;align-items:center;">ชื่อ<%- getSortIcon('name') %></a></th>
                <% if (typeof departments !== 'undefined' && departments.length > 0) { %>
                <th>หน่วยงาน</th>
                <% } %>
                <th><a href="<%= getSortUrl('category_id') %>" style="color:inherit;text-decoration:none;display:flex;align-items:center;">หมวดหมู่<%- getSortIcon('category_id') %></a></th>
                <th><a href="<%= getSortUrl('type') %>" style="color:inherit;text-decoration:none;display:flex;align-items:center;">ประเภท<%- getSortIcon('type') %></a></th>
                <th><a href="<%= getSortUrl('status') %>" style="color:inherit;text-decoration:none;display:flex;align-items:center;">สถานะ<%- getSortIcon('status') %></a></th>
                <th><a href="<%= getSortUrl('quantity') %>" style="color:inherit;text-decoration:none;display:flex;align-items:center;">คงเหลือ<%- getSortIcon('quantity') %></a></th>
                <th><a href="<%= getSortUrl('price_per_unit') %>" style="color:inherit;text-decoration:none;display:flex;align-items:center;">ราคา/หน่วย<%- getSortIcon('price_per_unit') %></a></th>
                <th><a href="<%= getSortUrl('location') %>" style="color:inherit;text-decoration:none;display:flex;align-items:center;">สถานที่<%- getSortIcon('location') %></a></th>
                <th><a href="<%= getSortUrl('created_at') %>" style="color:inherit;text-decoration:none;display:flex;align-items:center;">วันที่เพิ่ม<%- getSortIcon('created_at') %></a></th>
                <% if (currentUser && (currentUser.role==='admin' || currentUser.role==='superadmin')) { %>
                  <th>จัดการ</th>
                  <% } %>
              </tr>
            </thead>
            <tbody>
              <% assets.forEach(asset=> { %>
                <tr>
                  <td><strong>
                      <%= asset.asset_code %>
                    </strong></td>
                  <td><a href="/assets/<%= asset.id %>" class="asset-link">
                      <%= asset.name %>
                    </a></td>
                  <% if (typeof departments !== 'undefined' && departments.length > 0) { %>
                  <td>
                    <span class="badge badge-secondary"><%= asset.department ? asset.department.name : '-' %></span>
                  </td>
                  <% } %>
                  <td>
                    <%= asset.category ? asset.category.name : '-' %>
                  </td>
                  <td>
                    <span class="badge <%= asset.type === 'consumable' ? 'badge-warning' : 'badge-info' %>">
                      <%= asset.type==='consumable' ? 'ใช้แล้วหมดไป' : 'ยืม-คืน' %>
                    </span>
                  </td>
                  <td>
                    <span
                      class="badge <%= asset.status === 'active' ? 'badge-success' : asset.status === 'damaged' ? 'badge-danger' : asset.status === 'repairing' ? 'badge-warning' : 'badge-info' %>">
                      <%= asset.status==='active' ? 'ใช้งานได้' : asset.status==='damaged' ? 'ชำรุด' :
                        asset.status==='repairing' ? 'ซ่อมแซม' : 'จำหน่ายแล้ว' %>
                    </span>
                  </td>
                  <td>
                    <% if (asset.min_quantity> 0 && asset.quantity <= asset.min_quantity) { %>
                        <span style="color: var(--danger); font-weight: 600;">
                          <%= asset.quantity %>
                            <%= asset.unit %> <i data-lucide="triangle-alert"></i>
                        </span>
                        <% } else { %>
                          <%= asset.quantity %>
                            <%= asset.unit %>
                              <% } %>
                  </td>
                  <td>
                    <%= asset.price_per_unit ? parseFloat(asset.price_per_unit).toLocaleString('th-TH') + ' บาท' : '-' %>
                  </td>
                  <td>
                    <%= asset.location || '-' %>
                  </td>
                  <td>
                    <%= asset.createdAt ? new Date(asset.createdAt).toLocaleString('th-TH',
                      {year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '-' %>
                  </td>
                  <% if (currentUser && (currentUser.role==='admin' || currentUser.role==='superadmin')) { %>
                    <td>
                      <div class="btn-group">
                        <a href="/assets/edit/<%= asset.id %>" class="btn btn-warning btn-xs"><i data-lucide="pencil" style="width:14px;height:14px"></i></a>
                        <form action="/assets/delete/<%= asset.id %>" method="POST" style="display:inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="button" class="btn btn-danger btn-xs btn-delete"
                            data-name="<%= asset.name %>"><i data-lucide="trash-2" style="width:14px;height:14px"></i></button>
                        </form>
                      </div>
                    </td>
                    <% } %>
                </tr>
                <% }) %>
            </tbody>
          </table>
        </div>
        <%- include('../partials/pagination', { pagination, buildQuery }) %>
          <% } %>
  </div>
</div>