<div class="page-header">
  <div>
    <h2><i data-lucide="tag"></i> ทรัพย์สิน</h2>
    <div class="breadcrumb">หน้าหลัก / ทรัพย์สิน</div>
  </div>
  <% if (currentUser && currentUser.role==='admin' ) { %>
    <a href="/assets/create" class="btn btn-primary"><i data-lucide="plus" style="width:14px;height:14px"></i> เพิ่มทรัพย์สิน</a>
    <% } %>
</div>

<!-- Filters -->
<form method="GET" action="/assets">
  <div class="filter-bar">
    <div class="filter-tabs">
      <a href="/assets" class="filter-tab <%= !filters.type ? 'active' : '' %>">ทั้งหมด</a>
      <a href="/assets?type=consumable"
        class="filter-tab <%= filters.type === 'consumable' ? 'active' : '' %>">ใช้แล้วหมดไป</a>
      <a href="/assets?type=borrowable"
        class="filter-tab <%= filters.type === 'borrowable' ? 'active' : '' %>">ยืม-คืนได้</a>
    </div>
    <div class="search-input">
      <input type="text" name="search" value="<%= filters.search %>" placeholder="ค้นหาชื่อหรือรหัส...">
    </div>
    <select class="form-control" name="category_id" style="max-width:200px" onchange="this.form.submit()">
      <option value="">-- หมวดหมู่ทั้งหมด --</option>
      <% categories.forEach(cat=> { %>
        <option value="<%= cat.id %>" <%=filters.category_id==cat.id ? 'selected' : '' %>><%= cat.name %>
        </option>
        <% }) %>
    </select>
    <button type="submit" class="btn btn-outline btn-sm"><i data-lucide="search" style="width:14px;height:14px"></i> ค้นหา</button>
  </div>
</form>

<div class="card">
  <div class="card-body">
    <% if (assets.length===0) { %>
      <div class="empty-state">
        <div class="empty-icon"><i data-lucide="package"></i></div>
        <h4>ไม่พบทรัพย์สิน</h4>
        <p>ลองเปลี่ยนตัวกรอง หรือเพิ่มทรัพย์สินใหม่</p>
      </div>
      <% } else { %>
        <div class="table-responsive">
          <table>
            <thead>
              <tr>
                <th>รหัส</th>
                <th>ชื่อ</th>
                <th>หมวดหมู่</th>
                <th>ประเภท</th>
                <th>สถานะ</th>
                <th>คงเหลือ</th>
                <th>ราคา/หน่วย</th>
                <th>สถานที่</th>
                <th>วันที่เพิ่ม</th>
                <% if (currentUser && currentUser.role==='admin' ) { %>
                  <th>จัดการ</th>
                  <% } %>
              </tr>
            </thead>
            <tbody>
              <% assets.forEach(asset=> { %>
                <tr>
                  <td><strong>
                      <%= asset.asset_code %>
                    </strong></td>
                  <td><a href="/assets/<%= asset.id %>" class="asset-link">
                      <%= asset.name %>
                    </a></td>
                  <td>
                    <%= asset.category ? asset.category.name : '-' %>
                  </td>
                  <td>
                    <span class="badge <%= asset.type === 'consumable' ? 'badge-warning' : 'badge-info' %>">
                      <%= asset.type==='consumable' ? 'ใช้แล้วหมดไป' : 'ยืม-คืน' %>
                    </span>
                  </td>
                  <td>
                    <span
                      class="badge <%= asset.status === 'active' ? 'badge-success' : asset.status === 'damaged' ? 'badge-danger' : asset.status === 'repairing' ? 'badge-warning' : 'badge-info' %>">
                      <%= asset.status==='active' ? 'ใช้งานได้' : asset.status==='damaged' ? 'ชำรุด' :
                        asset.status==='repairing' ? 'ซ่อมแซม' : 'จำหน่ายแล้ว' %>
                    </span>
                  </td>
                  <td>
                    <% if (asset.min_quantity> 0 && asset.quantity <= asset.min_quantity) { %>
                        <span style="color: var(--danger); font-weight: 600;">
                          <%= asset.quantity %>
                            <%= asset.unit %> <i data-lucide="triangle-alert"></i>
                        </span>
                        <% } else { %>
                          <%= asset.quantity %>
                            <%= asset.unit %>
                              <% } %>
                  </td>
                  <td>
                    <%= asset.price_per_unit ? parseFloat(asset.price_per_unit).toLocaleString('th-TH') + ' ฿' : '-' %>
                  </td>
                  <td>
                    <%= asset.location || '-' %>
                  </td>
                  <td>
                    <%= asset.createdAt ? new Date(asset.createdAt).toLocaleString('th-TH',
                      {year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '-' %>
                  </td>
                  <% if (currentUser && currentUser.role==='admin' ) { %>
                    <td>
                      <div class="btn-group">
                        <a href="/assets/edit/<%= asset.id %>" class="btn btn-warning btn-xs"><i data-lucide="pencil" style="width:14px;height:14px"></i></a>
                        <form action="/assets/delete/<%= asset.id %>" method="POST" style="display:inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="button" class="btn btn-danger btn-xs btn-delete"
                            data-name="<%= asset.name %>"><i data-lucide="trash-2" style="width:14px;height:14px"></i></button>
                        </form>
                      </div>
                    </td>
                    <% } %>
                </tr>
                <% }) %>
            </tbody>
          </table>
        </div>
        <%- include('../partials/pagination', { pagination, buildQuery }) %>
          <% } %>
  </div>
</div>