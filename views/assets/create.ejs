<div class="page-header">
  <div>
    <h2><i data-lucide="plus" style="width:14px;height:14px"></i> เพิ่มทรัพย์สิน</h2>
    <div class="breadcrumb">หน้าหลัก / ทรัพย์สิน / เพิ่มใหม่</div>
  </div>
  <a href="/assets" class="btn btn-outline"><i data-lucide="arrow-left" style="width:14px;height:14px"></i> กลับ</a>
</div>
<div class="card">
  <div class="card-body">
    <form action="/assets/create" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <% if (typeof departments !== 'undefined' && departments.length > 0) { %>
      <div class="form-group">
        <label class="form-label" for="department_id">หน่วยงาน *</label>
        <select class="form-control" id="department_id" name="department_id" required>
          <option value="">-- เลือกหน่วยงาน --</option>
          <% departments.forEach(dept => { %>
            <option value="<%= dept.id %>"><%= dept.name %></option>
          <% }) %>
        </select>
      </div>
      <% } else if (currentUser && currentUser.department_name) { %>
      <div class="form-group">
        <label class="form-label">หน่วยงาน</label>
        <input type="text" class="form-control" value="<%= currentUser.department_name %>" disabled>
        <input type="hidden" id="current_dept_id" value="<%= currentUser.department_id || '' %>">
        <small style="color:var(--text-muted)">ทรัพย์สินจะถูกเพิ่มในหน่วยงานของคุณโดยอัตโนมัติ</small>
      </div>
      <% } %>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="category_id">หมวดหมู่ *</label>
          <select class="form-control" id="category_id" name="category_id" required>
            <option value="">-- เลือกหมวดหมู่ --</option>
            <% categories.forEach(cat=> { %>
              <option value="<%= cat.id %>" data-prefix="<%= cat.sku_prefix || '' %>">
                <%= cat.name %> (<%= cat.sku_prefix || '-' %>)
              </option>
              <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="asset_code">รหัสทรัพย์สิน (สร้างอัตโนมัติ)</label>
          <input type="text" class="form-control" id="asset_code" name="asset_code" readonly
            placeholder="เลือกหมวดหมู่เพื่อสร้างรหัสอัตโนมัติ" style="background:var(--bg-secondary)">
          <small id="asset_code_info" style="display:block; margin-top:4px; font-size:11px;"></small>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="name">ชื่อทรัพย์สิน *</label>
          <input type="text" class="form-control" id="name" name="name" required placeholder="กรอกชื่อทรัพย์สิน">
        </div>
        <div class="form-group">
          <label class="form-label" for="type">ประเภท *</label>
          <select class="form-control" id="type" name="type" required>
            <option value="consumable">ใช้แล้วหมดไป (Consumable)</option>
            <option value="borrowable">ยืม-คืนได้ (Borrowable)</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" for="description">คำอธิบาย</label>
        <textarea class="form-control" id="description" name="description" placeholder="กรอกรายละเอียด"></textarea>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="quantity">จำนวน *</label>
          <input type="number" class="form-control" id="quantity" name="quantity" required min="0" value="0">
        </div>
        <div class="form-group">
          <label class="form-label" for="unit">หน่วยนับ *</label>
          <input type="text" class="form-control" id="unit" name="unit" required value="ชิ้น"
            placeholder="ชิ้น, อัน, กล่อง">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="price_per_unit">ราคาต่อหน่วย (฿)</label>
          <input type="number" class="form-control" id="price_per_unit" name="price_per_unit" min="0" step="0.01"
            value="0">
        </div>
        <div class="form-group">
          <label class="form-label" for="min_quantity">จำนวนขั้นต่ำ (แจ้งเตือน)</label>
          <input type="number" class="form-control" id="min_quantity" name="min_quantity" min="0" value="0">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="location">สถานที่จัดเก็บ</label>
          <input type="text" class="form-control" id="location" name="location" placeholder="เช่น ห้องเก็บของ ชั้น 2">
        </div>
        <div class="form-group">
          <label class="form-label" for="status">สถานะ</label>
          <select class="form-control" id="status" name="status">
            <option value="active">ใช้งานได้</option>
            <option value="damaged">ชำรุด</option>
            <option value="repairing">ซ่อมแซม</option>
            <option value="disposed">จำหน่ายแล้ว</option>
          </select>
        </div>
      </div>

      <button type="submit" class="btn btn-primary"><i data-lucide="save" style="width:14px;height:14px"></i>
        บันทึก</button>
    </form>
  </div>
</div>

<script>
  function fetchAssetCode() {
    const codeInput = document.getElementById('asset_code');
    const codeInfo = document.getElementById('asset_code_info');
    const categorySelect = document.getElementById('category_id');
    const categoryId = categorySelect.value;
    
    const departmentSelect = document.getElementById('department_id');
    const departmentId = departmentSelect ? departmentSelect.value : document.getElementById('current_dept_id')?.value;

    if (!categoryId) {
      codeInput.value = '';
      if (codeInfo) codeInfo.textContent = '';
      return;
    }
    
    codeInput.value = 'กำลังสร้างรหัส...';
    if (codeInfo) codeInfo.textContent = '';
    
    let url = '/assets/api/next-code/' + categoryId;
    if (departmentId) {
      url += '/' + departmentId;
    }

    fetch(url)
      .then(res => res.json())
      .then(data => {
        codeInput.value = data.code || '';
        if (codeInfo && data.code) {
          codeInfo.textContent = 'มีทรัพย์สินในหมวดนี้แล้ว ' + data.existingCount + ' รายการ (รหัสถัดไป: ' + data.code + ')';
          codeInfo.style.color = 'var(--text-muted)';
        }
      })
      .catch(e => {
        codeInput.value = '';
        if (codeInfo) codeInfo.textContent = 'ไม่สามารถสร้างรหัสอัตโนมัติได้';
      });
  }

  document.getElementById('category_id').addEventListener('change', fetchAssetCode);
  const deptSelect = document.getElementById('department_id');
  if (deptSelect) {
    deptSelect.addEventListener('change', fetchAssetCode);
  }
</script>