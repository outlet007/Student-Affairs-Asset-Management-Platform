<div class="page-header">
  <div>
    <h2><i data-lucide="users"></i> จัดการผู้ใช้งาน</h2>
    <div class="breadcrumb">หน้าหลัก / ผู้ใช้งาน</div>
  </div>
  <a href="/users/create" class="btn btn-primary"><i data-lucide="plus" style="width:14px;height:14px"></i> เพิ่มผู้ใช้งาน</a>
</div>

<div class="card">
  <div class="card-body">
    <% if (users.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon"><i data-lucide="user"></i></div>
        <h4>ยังไม่มีผู้ใช้งาน</h4>
        <p>เริ่มต้นด้วยการเพิ่มผู้ใช้งานใหม่</p>
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>ชื่อผู้ใช้</th>
              <th>ชื่อ-นามสกุล</th>
              <th>อีเมล</th>
              <th>สิทธิ์</th>
              <th>วันที่สร้าง</th>
              <th>จัดการ</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach((user, i) => { %>
              <tr>
                <td><%= i + 1 %></td>
                <td><strong><%= user.username %></strong></td>
                <td><%= user.full_name %></td>
                <td><%= user.email || '-' %></td>
                <td>
                  <span class="badge <%= user.role === 'admin' ? 'badge-primary' : 'badge-info' %>">
                    <%= user.role === 'admin' ? 'ผู้ดูแลระบบ' : 'เจ้าหน้าที่' %>
                  </span>
                </td>
                <td><%= user.createdAt ? new Date(user.createdAt).toLocaleString('th-TH', {year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '-' %></td>
                <td>
                  <div class="btn-group">
                    <a href="/users/edit/<%= user.id %>" class="btn btn-warning btn-xs"><i data-lucide="pencil" style="width:14px;height:14px"></i> แก้ไข</a>
                    <form action="/users/delete/<%= user.id %>" method="POST" style="display:inline">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="button" class="btn btn-danger btn-xs btn-delete" data-name="<%= user.full_name %>"><i data-lucide="trash-2" style="width:14px;height:14px"></i> ลบ</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>
