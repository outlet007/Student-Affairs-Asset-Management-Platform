# =============================================
# Student Affairs Asset Management Platform
# Environment Configuration Template
# =============================================
# คัดลอกไฟล์นี้ แล้วเปลี่ยนชื่อเป็น .env
# จากนั้นกรอกค่าที่เหมาะสมสำหรับ server ของท่าน

# ---- Database Configuration ----
DB_HOST=127.0.0.1
DB_PORT=3036
DB_NAME=asset_management
DB_USER=asset_user
# กำหนด password ที่ปลอดภัย (ห้ามใช้ค่า default)
DB_PASSWORD=CHANGE_THIS_PASSWORD
DB_ROOT_PASSWORD=CHANGE_THIS_ROOT_PASSWORD

# ---- Application ----
PORT=3000
# กำหนด Session Secret ที่ซับซ้อน (อย่างน้อย 32 ตัวอักษร)
SESSION_SECRET=CHANGE_THIS_SESSION_SECRET_MIN_32_CHARS
NODE_ENV=production

# ---- Port ที่เปิดให้เข้าถึงจากภายนอก ----
# Port ที่ browser จะใช้เข้าถึง เช่น http://server-ip:8021
APP_PORT=8021
