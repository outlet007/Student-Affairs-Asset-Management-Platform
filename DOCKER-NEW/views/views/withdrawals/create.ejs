<div class="page-header">
  <div>
    <h2><i data-lucide="package-minus"></i> เบิกใช้ทรัพย์สิน</h2>
    <div class="breadcrumb">หน้าหลัก / เบิกใช้ / สร้างรายการ</div>
  </div>
  <a href="/withdrawals" class="btn btn-outline"><i data-lucide="arrow-left" style="width:14px;height:14px"></i> กลับ</a>
</div>
<div class="card">
  <div class="card-body">
    <form action="/withdrawals/create" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      
      <!-- Asset search & filter -->
      <div class="form-row" style="margin-bottom:0">
        <div class="form-group">
          <label class="form-label" for="asset_search"><i data-lucide="search" style="width:14px;height:14px;vertical-align:middle"></i> ค้นหาทรัพย์สิน</label>
          <input type="text" class="form-control" id="asset_search" placeholder="พิมพ์ชื่อทรัพย์สิน..." autocomplete="off">
        </div>
        <div class="form-group">
          <label class="form-label" for="category_filter"><i data-lucide="tag" style="width:14px;height:14px;vertical-align:middle"></i> หมวดหมู่</label>
          <select class="form-control" id="category_filter">
            <option value="">-- ทุกหมวดหมู่ --</option>
            <% categories.forEach(c => { %>
              <option value="<%= c.id %>"><%= c.name %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <div id="asset_count_info" style="font-size:0.82rem;color:var(--text-secondary);margin-bottom:0.75rem;margin-top:-0.25rem"></div>

      <div class="form-group">
        <label class="form-label" for="asset_id">เลือกทรัพย์สิน *</label>
        <select class="form-control" id="asset_id" name="asset_id" required>
          <option value="">-- เลือกทรัพย์สิน --</option>
          <% assets.forEach(a => { %>
            <option value="<%= a.id %>" data-name="<%= a.name.toLowerCase() %>" data-category="<%= a.category_id || '' %>">
              <%= a.name %> (คงเหลือ: <%= a.quantity %> <%= a.unit %>)
            </option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label" for="quantity">จำนวนที่ต้องการเบิก *</label>
        <input type="number" class="form-control" id="quantity" name="quantity" required min="1" value="1">
      </div>
      <div class="form-group">
        <label class="form-label" for="purpose">วัตถุประสงค์</label>
        <textarea class="form-control" id="purpose" name="purpose" placeholder="ระบุวัตถุประสงค์ในการเบิก"></textarea>
      </div>
      <button type="submit" class="btn btn-primary"><i data-lucide="package-minus"></i> ส่งคำขอเบิก</button>
    </form>
  </div>
</div>

<script>
(function() {
  const searchInput  = document.getElementById('asset_search');
  const catFilter    = document.getElementById('category_filter');
  const select       = document.getElementById('asset_id');
  const countInfo    = document.getElementById('asset_count_info');
  const allOptions   = Array.from(select.options).filter(o => o.value !== '');

  function updateCount(visible) {
    countInfo.textContent = visible === allOptions.length
      ? `แสดง ${visible} รายการ`
      : `แสดง ${visible} จาก ${allOptions.length} รายการ`;
  }

  function filterAssets() {
    const term = searchInput.value.toLowerCase().trim();
    const cat  = catFilter.value;

    // Reset: add all back first
    while (select.options.length > 1) select.remove(1);

    let count = 0;
    allOptions.forEach(opt => {
      const nameMatch = !term || opt.dataset.name.includes(term);
      const catMatch  = !cat  || opt.dataset.category === cat;
      if (nameMatch && catMatch) {
        select.appendChild(opt.cloneNode(true));
        count++;
      }
    });
    updateCount(count);

    // Auto-select if only one result
    if (count === 1) select.selectedIndex = 1;
    else select.selectedIndex = 0;
  }

  searchInput.addEventListener('input', filterAssets);
  catFilter.addEventListener('change', filterAssets);
  updateCount(allOptions.length);
})();
</script>
