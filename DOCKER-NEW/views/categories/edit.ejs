<div class="page-header">
  <div>
    <h2><i data-lucide="pencil" style="width:14px;height:14px"></i> แก้ไขหมวดหมู่</h2>
    <div class="breadcrumb">หน้าหลัก / หมวดหมู่ / แก้ไข</div>
  </div>
  <a href="/categories" class="btn btn-outline"><i data-lucide="arrow-left" style="width:14px;height:14px"></i> กลับ</a>
</div>
<div class="card">
  <div class="card-body">
    <form action="/categories/edit/<%= category.id %>" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="name">ชื่อหมวดหมู่ *</label>
          <input type="text" class="form-control" id="name" name="name" value="<%= category.name %>" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="sku_prefix">รหัส SKU (ตัวอักษร 2-3 ตัว) *</label>
          <input type="text" class="form-control" id="sku_prefix" name="sku_prefix"
            value="<%= category.sku_prefix || '' %>" required maxlength="3" minlength="2"
            style="text-transform:uppercase" pattern="[A-Za-z]{2,3}">
          <small style="color:var(--text-muted)">ใช้เป็นรหัสนำหน้าทรัพย์สิน เช่น OFC-0001</small>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" for="description">คำอธิบาย</label>
        <textarea class="form-control" id="description" name="description"><%= category.description || '' %></textarea>
      </div>
      <% if (typeof departments !== 'undefined' && departments.length > 0) { %>
      <div class="form-group">
        <label class="form-label" for="department_id">หน่วยงานที่ใช้ *</label>
        <select class="form-control" id="department_id" name="department_id" required>
          <option value="">-- เลือกหน่วยงาน --</option>
          <% departments.forEach(dept => { %>
            <option value="<%= dept.id %>" <%= category.department_id == dept.id ? 'selected' : '' %>><%= dept.name %></option>
          <% }) %>
        </select>
      </div>
      <% } else if (currentUser && currentUser.department_name) { %>
      <div class="form-group">
        <label class="form-label">หน่วยงาน</label>
        <input type="text" class="form-control" value="<%= currentUser.department_name %>" disabled>
      </div>
      <% } %>
      <button type="submit" class="btn btn-primary"><i data-lucide="save" style="width:14px;height:14px"></i>
        บันทึก</button>
    </form>
  </div>
</div>