<div class="page-header">
  <div>
    <h2><i data-lucide="plus" style="width:14px;height:14px"></i> เพิ่มหน่วยงาน</h2>
    <div class="breadcrumb">หน้าหลัก / หน่วยงาน / เพิ่มใหม่</div>
  </div>
  <a href="/departments" class="btn btn-outline"><i data-lucide="arrow-left" style="width:14px;height:14px"></i> กลับ</a>
</div>

<div class="card">
  <div class="card-body">
    <form action="/departments/create" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label class="form-label" for="code">รหัสหน่วยงาน (ตัวย่อ) *</label>
        <input type="text" class="form-control" id="code" name="code" required placeholder="เช่น REG, HR, IT" maxlength="20">
      </div>
      <div class="form-group">
        <label class="form-label" for="name">ชื่อหน่วยงาน *</label>
        <input type="text" class="form-control" id="name" name="name" required placeholder="กรอกชื่อหน่วยงาน">
      </div>
      <div class="form-group">
        <label class="form-label" for="description">รายละเอียด</label>
        <textarea class="form-control" id="description" name="description" rows="3" placeholder="กรอกรายละเอียดหน่วยงาน"></textarea>
      </div>
      <button type="submit" class="btn btn-primary">💾 บันทึก</button>
    </form>
  </div>
</div>
